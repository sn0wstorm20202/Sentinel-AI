# ============================
# Sentinel AI Frontend
# ============================

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Sentinel AI
VITE_APP_VERSION=1.0.0
VITE_ENABLE_GRAPH=true
VITE_ENABLE_COPILOT=true
VITE_ENABLE_ANALYTICS=true
VITE_REQUEST_TIMEOUT=30000
VITE_MAP_PROVIDER=reactflow
VITE_DEFAULT_THEME=dark
VITE_ENABLE_DEBUG=false

# If authentication is added later:
VITE_AUTH_PROVIDER=jwt
VITE_TOKEN_STORAGE=localStorage
