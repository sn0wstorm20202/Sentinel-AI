# Sentinel AI - Environment Variables
# Separate Frontend and Backend configurations

# --------------------------
# FRONTEND CONFIGURATION
# --------------------------
# The URL of the Sentinel API Backend (accessed by the client browser).
# In production with Nginx, this points to the reverse proxy endpoint.
NEXT_PUBLIC_API_URL=http://localhost:8080

# --------------------------
# BACKEND CONFIGURATION
# --------------------------
# Application port for the FastAPI server
PORT=8000

# Number of Gunicorn workers for production (recommend 4-8 depending on cores)
WORKERS=4

# Secret used for JWT token signing in production
# GENERATE A NEW SECRET IN PRODUCTION: openssl rand -hex 32
JWT_SECRET=super_secret_placeholder_replace_me_in_prod

# Allowed CORS origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# (Optional) Postgres database URL
# DATABASE_URL=postgresql://user:password@localhost/sentinel

# (Optional) Redis URL for caching and rate limiting
# REDIS_URL=redis://localhost:6379/0
