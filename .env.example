# Sentinel AI Environment Variables
# Do not place actual secrets in this file.

# API Configuration
PORT=8000
ENVIRONMENT=production

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=sentinel
DB_PASSWORD=your_password
DB_NAME=sentinel_db

# Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT / Auth
SECRET_KEY=generate_a_secure_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
